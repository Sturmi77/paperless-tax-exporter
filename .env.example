# Paperless Tax Exporter – Konfiguration
# Kopiere diese Datei nach .env und trage deine Werte ein.

# ── Paperless NGX ────────────────────────────────────────────────────
PAPERLESS_URL=http://192.168.178.115:8000
PAPERLESS_TOKEN=dein-token-hier

# ── Ollama (Stufe 2: OCR-Analyse) ────────────────────────────────────
OLLAMA_URL=http://192.168.178.115:11434
OLLAMA_MODEL=qwen2.5:3b

# ── Pfade ─────────────────────────────────────────────────────────────
# Linux-Pfad im Container (Volume-Mount)
OUTPUT_DIR=/output

# Windows UNC-Pfad für Excel-Hyperlinks (Backslashes verdoppeln)
WINDOWS_UNC_PATH=\\SynologyDS923\downloads\steuerberater

# ── Hyperlink-Modus (Issue #8) ──────────────────────────────────────
# cell  = CELL("filename")-Formel – portabel, funktioniert nach Ordner-Verschiebung (empfohlen)
# unc   = absoluter UNC-Pfad (bisheriges Verhalten, Fallback)
HYPERLINK_MODE=cell

# Spalte K mit kopierbarem UNC-Pfad (plain text für E-Mail/Chat)
# true = Spalte K einblenden | false = Spalte K ausblenden (default)
INCLUDE_TEXT_PATH=false

# ── Image Tag ───────────────────────────────────────────────────────
# latest = stabile Version, develop = Testversion
IMAGE_TAG=latest

# ── Zeitzone ─────────────────────────────────────────────────────────
TZ=Europe/Vienna
