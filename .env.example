# Paperless Tax Exporter – Konfiguration
# Kopiere diese Datei nach .env und trage deine Werte ein.

# ── Paperless NGX ────────────────────────────────────────────────────
PAPERLESS_URL=http://192.168.178.115:8000
PAPERLESS_TOKEN=dein-token-hier

# ── Ollama (Stufe 2: OCR-Analyse) ────────────────────────────────────
OLLAMA_URL=http://192.168.178.115:11434
OLLAMA_MODEL=qwen2.5:3b

# ── Pfade ─────────────────────────────────────────────────────────────
# Linux-Pfad im Container (Volume-Mount)
OUTPUT_DIR=/output

# Windows UNC-Pfad für Excel-Hyperlinks (Backslashes verdoppeln)
WINDOWS_UNC_PATH=\\SynologyDS923\downloads\steuerberater

# ── Zeitzone ─────────────────────────────────────────────────────────
TZ=Europe/Vienna
